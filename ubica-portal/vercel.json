{
    "rewrites": [
        {
            "source": "/((?!ami-fincas).*)",
            "has": [
                {
                    "type": "host",
                    "value": "amifincas.es"
                }
            ],
            "destination": "/index.html"
        },
        {
            "source": "/((?!ami-fincas).*)",
            "has": [
                {
                    "type": "host",
                    "value": "www.amifincas.es"
                }
            ],
            "destination": "/index.html"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}